# PostgreSQL Database Configuration
DB_HOST=localhost
DB_PORT=5433
DB_USER=postgres
DB_PASSWORD=postgres
DB_DATABASE=iam

# RabbitMQ Configuration
RABBITMQ_CONN=amqp://agi_rabbitmq_user:agi_rabbitmq_user@localhost:5672/agi_rabbitmq_user
AI_PROCESSING_QUEUE=ai_processing_queue
MATCH_REQUEST_QUEUE=match_request_queue
STUDENT_EMBEDDING_QUEUE=student_embedding_queue

# Model Configuration
# GLiNER base model (downloaded automatically from HuggingFace on first run)
GLINER_MODEL_NAME=urchade/gliner_base

# BGE-M3 embedding model (downloaded automatically on first run)
BGE_MODEL_NAME=BAAI/bge-m3

# HuggingFace token (optional but recommended for faster downloads)
HF_TOKEN=

# Model cache directory (models downloaded here once, reused on restart)
MODEL_CACHE_DIR=./model_cache
